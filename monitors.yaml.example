# ─────────────────────────────────────────────────────────────
# Monitor declarations — passed to MCP server via `--monitors <path>`
# ─────────────────────────────────────────────────────────────
# Each monitor here is auto-registered at MCP server startup via
# smartbuilding_monitor_ctl register_source. videostream-analytics
# (:8999) must be reachable at startup; if not, MCP server logs a
# warning and continues (use the smartbuilding_monitors_compose tool
# to retry later: action=up).
#
# `use_case` must reference a key in config.yaml's `use_case_dict` —
# that's where video_summary_task / evaluate_rules_path / reports live.
#
# `source_url` accepts any URL scheme supported by videostream-analytics
# (rtsp / http / onvif / file / ...). `pipeline_config` is forwarded
# verbatim to videostream-analytics /register_source.
# ─────────────────────────────────────────────────────────────

monitors:
  cam_fridge:
    enabled: true
    name: "Fridge Camera"
    source_url: rtsp://localhost:8554/live/fridge
    use_case: fridge
    pipeline_config:
      motion: { enabled: true, diff_threshold: 25, area_ratio: 1.5, stable_frames: 30 }
      prefilter: { enabled: false }
      recording: { enabled: true, interval_seconds: 60, retention_days: 5 }
      segment: { max_duration: 10 }

  cam_child:
    enabled: true
    name: "Child Safety Camera"
    source_url: rtsp://localhost:8554/live/child
    use_case: child_safety
    pipeline_config:
      motion: { enabled: true, diff_threshold: 25 }
      # Hazard prefilter: NPU YOLO11s gates summary requests on target classes.
      prefilter:
        enabled: true
        model_path: ${HOME}/models/yolo11s.xml
        target_classes: [person, knife, scissors, bottle]
        min_confidence: 0.4
        detect_fps: 2
        min_frames_hit: 2
        long_side: 1280
      # ROI crop — only the target region is sent to the summary service.
      roi:
        enabled: true
        mode: crop
        expand: 0.25
        auto_split_area: 0.35
      recording: { enabled: true, interval_seconds: 60 }
      segment: { max_duration: 10 }

  cam_elder_bedroom:
    enabled: true
    name: "Elder Bedroom Camera"
    source_url: rtsp://localhost:8554/live/elder
    use_case: elder_wakeup
    pipeline_config:
      motion: { enabled: true, diff_threshold: 25 }
      recording: { enabled: true, interval_seconds: 60 }
      segment: { max_duration: 10 }

  cam_elder_bedroom_2:
    enabled: true
    name: "Elder Bedroom Camera 2"
    source_url: rtsp://localhost:8554/live/elder2
    use_case: elder_wakeup
    pipeline_config:
      motion: { enabled: true, diff_threshold: 25 }
      recording: { enabled: true, interval_seconds: 60 }
      segment: { max_duration: 10 }
