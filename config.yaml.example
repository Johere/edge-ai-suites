# ─────────────────────────────────────────────────────────────
# Prerequisites
# ─────────────────────────────────────────────────────────────
# ffmpeg    — required by scene_query for frame resize
#             Ubuntu/Debian: sudo apt install ffmpeg
#             macOS:         brew install ffmpeg
#
# ─────────────────────────────────────────────────────────────
# Data directory
# ─────────────────────────────────────────────────────────────
# All runtime data (DB, segments, logs) is stored under a single root directory.
# Set via environment variable — NOT configurable here:
#
#   export SMARTBUILDING_DATA_DIR=/path/to/data   # default: ~/.mcp-smartbuilding
#
# Layout under that directory:
#   smartbuilding.db          — SQLite database
#   segments/<monitor_id>/    — video segments + latest.jpg (written by videostream-analytics)
#     latest.jpg              — latest frame (read by scene_query)
#     queries/                — archived frames from scene_query calls
#   logs/reports/             — SRT debug artifacts from generate_report
# ─────────────────────────────────────────────────────────────

# multilevel-video-understanding service (video segment analysis)
summary_service:
  url: http://localhost:8192

# vllm-serving-ipex (VLM for scene_query — single-frame queries)
vlm_service:
  url: http://localhost:41091/v1
  model: default
  max_edge_px: 720   # resize longest edge to this before sending to VLM (uses ffmpeg)

# videostream-analytics microservice (motion detection, RTSP processing)
videostream_analytics:
  url: http://localhost:8999

poll_interval_ms: 5000
video_summary_max_concurrent: 2

# MCP Server HTTP port (for OpenClaw / Claude Desktop connections)
mcp:
  port: 3100

# Events Webhook port (receives events from videostream-analytics microservice)
events_webhook:
  port: 3101

# DB schema extensions: declare custom columns for video_summary_tasks and alerts.
# MCP server auto-applies ALTER TABLE on startup if columns are missing.
schema:
  video_summary_tasks:
    extensions:
      - { name: "event",      type: "text", required: true }   # use-case event type
      - { name: "severity",   type: "text", required: true }   # critical / warn / info
      - { name: "desc",       type: "text", required: true }   # one-sentence description
      - { name: "confidence", type: "real", required: false }  # optional VLM confidence
  alerts:
    extensions: []
  custom_tables: []
