{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "paths": {
      "@smartbuilding-video/db": ["../db/src/index.ts"],
      "@smartbuilding-video/tools": ["../tools/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../db" },
    { "path": "../tools" }
  ]
}
